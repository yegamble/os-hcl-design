{
  "name": "Combobox",
  "category": "primitive",
  "status": "stable",
  "version": "0.1.0",
  "library": "cmdk + Popover",
  "props": [
    { "name": "options", "type": "{ value: string; label: string }[]", "required": true },
    { "name": "value", "type": "string", "required": false },
    { "name": "onChange", "type": "(v: string) => void", "required": false },
    { "name": "placeholder", "type": "string", "required": false, "default": "Select…" },
    { "name": "emptyMessage", "type": "string", "required": false, "default": "No results." },
    { "name": "disabled", "type": "boolean", "required": false }
  ],
  "tokensUsed": [
    "color.surface.default",
    "color.surface.raised",
    "color.surface.elevated",
    "color.text.primary",
    "color.text.tertiary",
    "color.border.default",
    "color.border.subtle",
    "color.action.primary",
    "radius.button"
  ],
  "a11y": {
    "role": "combobox",
    "keyboard": ["Type", "Arrow", "Enter", "Esc"],
    "focus": "trigger + autofocus input",
    "minHitTarget": "44px"
  }
}
