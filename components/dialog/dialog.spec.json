{
  "name": "Dialog",
  "category": "overlay",
  "status": "stable",
  "version": "0.1.0",
  "primitive": "@radix-ui/react-dialog",
  "subcomponents": [
    "DialogTrigger",
    "DialogContent",
    "DialogTitle",
    "DialogDescription",
    "DialogClose"
  ],
  "tokensUsed": [
    "color.surface.raised",
    "color.border.subtle",
    "color.text.primary",
    "radius.sheet",
    "shadow.dialog"
