{
  "name": "Progress",
  "category": "feedback",
  "status": "stable",
  "version": "0.1.0",
  "props": [
    {
      "name": "value",
      "type": "number",
      "required": false,
      "description": "Current progress; omit for indeterminate."
    },
    { "name": "max", "type": "number", "required": false, "default": 100 },
    { "name": "aria-label", "type": "string", "required": false }
  ],
  "tokensUsed": ["color.surface.elevated", "color.action.primary", "radius.pill"],
  "a11y": { "role": "progressbar", "keyboard": [], "focus": "none", "minHitTarget": "n/a" }
}
