{
  "name": "os-hcl-design",
  "version": "0.1.0",
  "private": true,
  "description": "Apple-inspired design system for AI-consumable website generation.",
  "homepage": "https://github.com/yegamble/os-hcl-design",
  "repository": {
    "type": "git",
    "url": "https://github.com/yegamble/os-hcl-design.git"
  },
  "license": "MIT",
  "author": "Yosef Gamble <yegamble@gmail.com>",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.cjs,.mjs && stylelint \"**/*.css\" --allow-empty-input",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build-tokens": "node build-tokens.mjs",
    "build-llms-full": "node scripts/build-llms-full.mjs",
    "dev": "storybook dev -p 6006 --no-open",
    "build:storybook": "storybook build",
    "build": "pnpm run build-tokens && pnpm run build-llms-full && pnpm run build:storybook",
    "test:lint-rules": "node eslint-local-rules/__tests__/no-raw-hex-in-className.test.cjs",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "test:keyboard": "playwright test tests/keyboard",
    "check:depth": "node scripts/check-component-depth.mjs",
    "check:doc-sections": "node scripts/check-doc-sections.mjs",
    "check:agents-size": "node scripts/check-agents-md-size.mjs",
    "check:token-contrast": "node scripts/check-token-contrast.mjs",
    "check:css-budget": "node scripts/check-css-budget.mjs",
    "check:baseline-count": "node scripts/check-baseline-count.mjs",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:lint-rules && pnpm run build-tokens && pnpm run build-llms-full && pnpm run check:depth && pnpm run check:doc-sections && pnpm run check:agents-size && pnpm run check:token-contrast && pnpm run check:baseline-count && pnpm run build:storybook && pnpm run check:css-budget"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.2",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^9",
    "@storybook/addon-themes": "^9",
    "@storybook/react-vite": "^9",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "http-server": "^14.1.1",
    "markdownlint-cli2": "^0.13.0",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "storybook": "^9",
    "style-dictionary": "^4.0.0",
    "stylelint": "^16.6.1",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
