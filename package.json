{
  "name": "os-hcl-design",
  "version": "0.1.0",
  "private": true,
  "description": "Apple-inspired design system for AI-consumable website generation.",
  "homepage": "https://github.com/yegamble/os-hcl-design",
  "repository": {
    "type": "git",
    "url": "https://github.com/yegamble/os-hcl-design.git"
  },
  "license": "MIT",
  "author": "Yosef Gamble <yegamble@gmail.com>",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.cjs,.mjs && stylelint \"**/*.css\" --allow-empty-input",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "markdownlint-cli2": "^0.13.0",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "stylelint": "^16.6.1",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.5.4"
  }
}
